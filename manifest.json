{
  "manifest_version": 3,
  "name": "小红书助手",
  "version": "1.1.0",
  "description": "帮助自媒体作者提升小红书创作效率",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads",
    "identity"
  ],
  "host_permissions": [
    "https://www.doubao.com/chat/*",
    "https://www.xiaohongshu.com/*",
    "https://xhs-picasso.xiaohongshu.com/*",
    "https://xhs-img.xiaohongshu.com/*",
    "https://1259223433-0gnwuwcg9e.ap-beijing.tencentscf.com/*",
    "https://wenxin.baidu.com/*",
    "https://chat.deepseek.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16_new.svg",
      "48": "images/icon48_new.svg",
      "128": "images/icon128_new.svg"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.doubao.com/chat/*"],
      "js": ["usageCounter.js", "auth.js", "content.js"]
    },
    {
      "matches": ["https://www.xiaohongshu.com/*"],
      "js": ["usageCounter.js", "auth.js", "content.js"]
    },
    {
      "matches": ["https://wenxin.baidu.com/*"],
      "js": ["usageCounter.js", "auth.js", "content.js"]
    },
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["usageCounter.js", "auth.js", "content.js"]
     }
  ],
  "web_accessible_resources": [
    {
      "resources": ["usageCounter.js", "auth.js"],
      "matches": ["<all_urls>"]
    }
  ]
}